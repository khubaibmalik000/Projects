# Copy to config.env and fill in real values.
# config.env is git-ignored — never commit real IPs/passwords for production nodes.

NODE_A_HOST=                   # e.g. a public IP or DNS name — no shared private LAN required
NODE_B_HOST=                   # ditto for the peer
SSH_USER=ubuntu                # user with passwordless sudo on both nodes

PG_VERSION=16
PGDATA=/var/lib/postgresql/16/main
PG_CONF=/etc/postgresql/16/main/postgresql.conf
PG_HBA=/etc/postgresql/16/main/pg_hba.conf
PG_CONF_DIR=/etc/postgresql/16/main
PG_REWIND_BIN=/usr/lib/postgresql/16/bin/pg_rewind   # not on PATH on Ubuntu packages

REPLICATOR_USER=replicator
REPLICATOR_PASSWORD=changeme   # use a strong, unique password in real deployments
APP_DB=testdb
